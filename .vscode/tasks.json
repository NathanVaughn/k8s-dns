{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "install-pre-commit",
            "command": "uv run prek install",
            "type": "shell"
        },
        {
            "label": "pre-commit",
            "command": "uv run prek run --all-files",
            "type": "shell"
        },
        {
            "label": "run",
            "command": "uv run kopf run app.py --verbose",
            "type": "shell"
        },
        {
            "label": "build",
            "command": "docker build -t cr.nathanv.app/library/k8s-dns:latest -f docker/Dockerfile .",
            "type": "shell"
        }
    ]
}